#!/bin/sh
# =============================================================
# Disables compositor, notifications and configure processor governor
# Adapted for NixOS with i3/Hyprland support
# Original: gh0stzk | https://github.com/gh0stzk/dotfiles
# =============================================================

CACHE_DIR="$HOME/.cache/$USER"
CACHE_FILE="$CACHE_DIR/gamemode_state"
CPU_GOVERNOR_PATH="/sys/devices/system/cpu/cpu0/cpufreq/scaling_governor"
PICOM_CONF="$HOME/dotfiles/config/picom/picom.conf"

mkdir -p "$CACHE_DIR"
[ -f "$CACHE_FILE" ] || echo "Off" > "$CACHE_FILE"

is_wayland() {
    [ -n "$WAYLAND_DISPLAY" ]
}

get_state() {
    head -n 1 "$CACHE_FILE" 2>/dev/null || echo "Off"
}

set_cpu_governor() {
    governor=$1
    echo "$governor" | pkexec tee /sys/devices/system/cpu/*/cpufreq/scaling_governor >/dev/null 2>&1
}

gamemode_on() {
    # Save current governor
    if [ -f "$CPU_GOVERNOR_PATH" ]; then
        cat "$CPU_GOVERNOR_PATH" > "$CACHE_DIR/cpu_governor"
        set_cpu_governor performance
    fi

    # Pause notifications
    dunstctl set-paused true

    # Kill compositor (picom on X11, nothing needed on Hyprland)
    if ! is_wayland; then
        pkill -f picom 2>/dev/null
    fi

    echo "On" > "$CACHE_FILE"
    dunstify -i games "Game Mode" "Game Mode activated. Compositor disabled, notifications paused, CPU set to performance."
}

gamemode_off() {
    # Resume notifications
    dunstctl set-paused false

    # Restart compositor on X11
    if ! is_wayland; then
        picom --config "$PICOM_CONF" &
    fi

    # Restore CPU governor
    if [ -f "$CACHE_DIR/cpu_governor" ]; then
        prev_governor=$(cat "$CACHE_DIR/cpu_governor")
        set_cpu_governor "$prev_governor"
    fi

    echo "Off" > "$CACHE_FILE"
    dunstify -i games "Game Mode" "Game Mode deactivated. Compositor restarted, notifications resumed."
}

toggle() {
    if [ "$(get_state)" = "Off" ]; then
        gamemode_on
    else
        gamemode_off
    fi
}

case "$1" in
    --toggle) toggle ;;
    --status) get_state ;;
    *)        echo "Usage: $0 [--toggle|--status]" ;;
esac
