#!/usr/bin/env bash

# Ensure only one instance runs
LOCKFILE="/tmp/fullscreen_watch.lock"
exec 9>"$LOCKFILE"
flock -n 9 || { echo "Already running"; exit 0; }
echo $$ >&9
trap 'rm -f "$LOCKFILE"' EXIT

EWW="eww -c $HOME/dotfiles/config/eww/bar"
BAR_HIDDEN=false

check_fullscreen() {
    # Check if any window on the focused workspace is fullscreen
    fs=$(i3-msg -t get_tree 2>/dev/null | jq -r '[.. | select(.focused? == true and .window? != null) | .fullscreen_mode] | first // 0')
    if [[ "$fs" == "1" ]]; then
        if [[ "$BAR_HIDDEN" == false ]]; then
            $EWW close bar 2>/dev/null
            BAR_HIDDEN=true
        fi
    else
        if [[ "$BAR_HIDDEN" == true ]]; then
            $EWW open bar 2>/dev/null
            BAR_HIDDEN=false
        fi
    fi
}

# Check on startup
check_fullscreen

# Watch for window and workspace changes
i3-msg -t subscribe -m '["window", "workspace"]' 2>/dev/null | while read -r _; do
    check_fullscreen
done
