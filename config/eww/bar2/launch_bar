#!/usr/bin/env bash

## Files and cmd
FILE="$HOME/.cache/eww_launch.xyz"
EWW="eww -c $HOME/dotfiles/config/eww/bar"

## Open widgets
run_eww() {
	${EWW} open-many \
         bar
}

## Launch or close widgets accordingly
if [[ -f "$FILE" ]] && pidof eww &>/dev/null; then
	## Bar is running — toggle it off
	${EWW} close-all && killall eww
	rm -f "$FILE"
else
	## Bar is not running — start daemon if needed, then open
	if ! pidof eww &>/dev/null; then
		${EWW} daemon
		## Wait for daemon to be ready (up to 5 seconds)
		for i in $(seq 1 10); do
			sleep 0.5
			pidof eww &>/dev/null && break
		done
	fi
	rm -f "$FILE"
	touch "$FILE"
	run_eww
fi
