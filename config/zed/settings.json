{
	"terminal": {
		"font_size": 16.0,
		"font_family": "Lilex",
	},
	"agent_servers": {
		"cursor": {
			"type": "registry",
		},
		"codex-acp": {
			"type": "registry",
		},
	},
	"project_panel": {
		"dock": "left",
	},
	"outline_panel": {
		"dock": "left",
	},
	"collaboration_panel": {
		"dock": "left",
	},
	"agent": {
		"default_model": {
   "provider": "openai-subscribed",
   "model": "gpt-5.5",
   "enable_thinking": true,
   "effort": "medium"
  },
  "sidebar_side": "right",
		"dock": "right",
		"favorite_models": [],
		"model_parameters": [],
	},
	"git_panel": {
		"dock": "left",
	},
	"session": {
		"trust_all_worktrees": true,
	},
	"theme": {
		"mode": "dark",
		"light": "One Light",
		"dark": "One Dark - Darkened",
	},
	"telemetry": {
		"diagnostics": false,
		"metrics": false,
	},
	"toolbar": {
		"breadcrumbs": false,
		"quick_actions": false,
	},
	"hard_tabs": true,
	"vim_mode": true,
	"icon_theme": {
		"mode": "system",
		"light": "Material Icon Theme",
		"dark": "Material Icon Theme",
	},
	"buffer_font_family": "Lilex",
	"ui_font_family": "SF Pro Display",
	"ui_font_size": 15.0,
	"agent_buffer_font_size": 14.0,
	"agent_ui_font_size": 16.0,
	"buffer_font_size": 15.0,
	"buffer_font_weight": 300,
	"autosave": "on_focus_change",
}
