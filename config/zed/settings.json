	},
	"hard_tabs": true,
	"vim_mode": true,
	"icon_theme": {
		"mode": "light",
		"light": "Material Icon Theme",
		"dark": "Material Icon Theme",
	},
	"buffer_font_family": "JetBrainsMono Nerd Font",
	"ui_font_size": 15,
	"agent_buffer_font_size": 13,
	"buffer_font_size": 15,
	"buffer_font_weight": 300,
	"autosave": "on_focus_change",
}
