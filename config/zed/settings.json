{
	"theme": "Tokyo Night",
	"agent_servers": {
		"opencode": {
			"type": "extension",
			"favorite_models": ["openai/gpt-5.4"],
			"default_config_options": {},
			"favorite_config_option_values": {},
		},
	},
	"telemetry": {
		"diagnostics": false,
