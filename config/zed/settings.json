{
	"language_models": {
  "lmstudio": {
   "api_url": "http://127.0.0.1:8317/v1/messages"
  },
  "opencode": {
   "show_go_models": false,
   "show_zen_models": false
  }
 },
 "terminal": {
		"font_size": 16.0,
		"font_family": "JetBrainsMono Nerd Font",
	},
	"agent_servers": {
  
 },
	"project_panel": {
		"dock": "left",
	},
	"outline_panel": {
		"dock": "left",
	},
	"collaboration_panel": {
		"dock": "left",
	},
	"auto_update": false,
	"agent": {
		"terminal_init_command": "claude",
  "default_model": {
			"provider": "openai-subscribed",
			"model": "gpt-5.6-sol",
			"enable_thinking": false,
			"effort": "xhigh",
		},
		"sidebar_side": "right",
		"dock": "right",
		"favorite_models": [],
		"model_parameters": [],
	},
	"git_panel": {
		"dock": "left",
	},
	"session": {
		"trust_all_worktrees": true,
	},
	"theme": {
		"mode": "dark",
		"light": "One Light",
		"dark": "Rosé Pine",
	},
	"telemetry": {
		"diagnostics": false,
		"metrics": false,
	},
	"toolbar": {
		"breadcrumbs": false,
		"quick_actions": false,
	},
	"hard_tabs": true,
	"vim_mode": true,
	"icon_theme": {
		"mode": "system",
		"light": "Material Icon Theme",
		"dark": "Material Icon Theme",
	},
	"buffer_font_family": "JetBrainsMono Nerd Font",
	"ui_font_family": "JetBrainsMono Nerd Font",
	"ui_font_size": 15.0,
	"agent_buffer_font_size": 14.0,
	"agent_ui_font_size": 16.0,
	"buffer_font_size": 15.0,
	"buffer_font_weight": 300,
	"autosave": "on_focus_change",
}
