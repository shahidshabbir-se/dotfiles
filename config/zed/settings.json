{
	"language_models": {},
	"terminal": {
		"font_size": 16.0,
		"font_family": "GeistMono Nerd Font",
	},
	"project_panel": {
		"dock": "left",
	},
	"buffer_line_height": "comfortable",
	"outline_panel": {
		"dock": "left",
	},
	"collaboration_panel": {
		"dock": "left",
	},
	"allow_rewrap": "anywhere",
	"format_on_save": "on",
	"auto_update": false,
	"agent": {
		"default_model": {
			"provider": "openai-subscribed",
			"model": "gpt-5.6-sol",
			"enable_thinking": false,
			"effort": "xhigh",
		},
		"sidebar_side": "right",
		"dock": "right",
		"favorite_models": [],
		"model_parameters": [],
	},
	"git_panel": {
		"dock": "left",
	},
	"session": {
		"trust_all_worktrees": true,
	},
	"theme": {
		"mode": "dark",
		"light": "One Light",
		"dark": "Tokyo Night",
	},
	"telemetry": {
		"diagnostics": false,
		"metrics": false,
	},
	"toolbar": {
		"breadcrumbs": false,
		"quick_actions": false,
	},
	"hard_tabs": true,
	"vim_mode": true,
	"icon_theme": {
		"mode": "system",
		"light": "Material Icon Theme",
		"dark": "Material Icon Theme",
	},
	"buffer_font_family": "GeistMono Nerd Font",
	"ui_font_size": 15.0,
	"agent_buffer_font_size": 14.0,
	"agent_ui_font_size": 15.0,
	"buffer_font_size": 15.0,
	"buffer_font_weight": 400,
	"autosave": "on_focus_change",
}
