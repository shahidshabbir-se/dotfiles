# Dunst config - Generated by matugen

[global]
monitor = 0
follow = mouse
origin = top-right
offset = 20x60
width = (300, 400)
scale = 0
notification_limit = 20
indicate_hidden = yes

# Appearance
transparency = 0
corner_radius = 6
gap_size = 4
separator_height = 1
separator_color = "{{colors.outline.default.hex}}"
padding = 15
horizontal_padding = 15
text_icon_padding = 0
frame_width = 0
frame_color = "{{colors.surface_container.default.hex}}"

# Typography
font = "JetBrainsMono NF Medium 9"
line_height = 0
markup = full
format = "<span size='xx-large' font_desc='JetBrainsMono NF 9' weight='bold' foreground='{{colors.primary.default.hex}}'>%s</span>\n%b"
alignment = center
vertical_alignment = center
show_age_threshold = 60
ignore_newline = no
stack_duplicates = no
hide_duplicate_count = yes

# Icons
enable_recursive_icon_lookup = yes
icon_theme = "Papirus-Dark, Adwaita"
icon_position = left
min_icon_size = 60
max_icon_size = 90
icon_corner_radius = 6

# Behavior
sort = no
idle_threshold = 0
show_indicators = yes
sticky_history = yes
history_length = 25
browser = /usr/bin/xdg-open
always_run_script = yes
ignore_dbusclose = no
force_xinerama = no

# Progress bar
progress_bar = yes
progress_bar_height = 10
progress_bar_frame_width = 0
progress_bar_min_width = 125
progress_bar_max_width = 250
progress_bar_corner_radius = 5

# Mouse actions
mouse_left_click = close_current
mouse_middle_click = do_action, close_current
mouse_right_click = close_all

title = Dunst
class = Dunst

[urgency_low]
timeout = 3
background = "{{colors.background.default.hex}}"
foreground = "{{colors.tertiary.default.hex}}"
highlight = "{{colors.primary.default.hex}}"

[urgency_normal]
timeout = 5
background = "{{colors.background.default.hex}}"
foreground = "{{colors.on_background.default.hex}}"
highlight = "{{colors.primary.default.hex}}"

[urgency_critical]
timeout = 0
background = "{{colors.background.default.hex}}"
foreground = "{{colors.error.default.hex}}"
highlight = "{{colors.error.default.hex}}"
