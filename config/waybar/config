{
  "layer": "top",
  "position": "top",
  "height": 42,
  "spacing": 0,
  "margin-left": 50,
  "margin-right": 50,
  "margin-top": 10,
  "margin-bottom": 0,
  "reload_style_on_change": true,

  "modules-left": ["custom/launcher", "cpu", "memory", "disk", "group/music-controls"],
  "modules-center": ["hyprland/workspaces"],
  "modules-right": ["group/music-bt", "group/hardware", "pulseaudio", "custom/updates", "clock", "custom/power"],

  "group/music-bt": {
    "orientation": "horizontal",
    "modules": ["custom/mplayer", "bluetooth"]
  },

  "group/music-controls": {
    "orientation": "horizontal",
    "modules": ["custom/cava-left", "custom/prev", "custom/play-pause", "custom/next", "custom/cava-right"]
  },

  "group/hardware": {
    "orientation": "horizontal",
    "modules": ["battery", "network"]
  },

  "hyprland/workspaces": {
    "on-click": "activate",
    "active-only": false,
    "all-outputs": true,
    "format": "{icon}",
    "persistent-workspaces": {
        "1": [],
        "2": [],
        "3": [],
        "4": [],
        "5": [],
        "6": []
    },
    "format-icons": {
      "active": "≤░χψ",
      "empty": "≤░ΣΛ",
      "default": "≤░Λι"
    }
  },

  "cpu": {
    "interval": 2,
    "format": "ΎΜδ {usage}%",
    "tooltip": false
  },

  "memory": {
    "interval": 3,
    "format": "ΎΦ╕ {used}",
    "tooltip": false
  },

  "disk": {
    "interval": 60,
    "format": "ΎΙΑ {used}",
    "tooltip": false
  },

  "network": {
    "interval": 3,
    "format-wifi": " {bandwidthTotalBytes}",
    "format-ethernet": "≤░ΙΑ {bandwidthTotalBytes}",
    "format-disconnected": "Offline",
    "on-click": "/home/shahid/.config/rofi/wifi-launch.sh",
    "tooltip": false
  },

  "bluetooth": {
    "format": "≤░Γψ",
    "format-connected": "≤░Γψ {num_connections}",
    "on-click": "/home/shahid/.config/rofi/bluetooth-launch.sh",
    "tooltip": false
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "Ύγσ Muted",
    "format-icons": {
      "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
    },
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-click-right": "OpenApps --soundcontrol",
    "tooltip": false
  },

  "battery": {
    "states": {
      "good": 99,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "≤░ΓΕ {capacity}%",
    "format-plugged": "ΎΘο {capacity}%",
    "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
    "battery": "BAT0",
    "tooltip": false
  },

  "clock": {
    "interval": 1,
    "format": "ΎΑΩ {:%I:%M %p}",
    "format-alt": "ΎΕ│ {:%a, %d %b %Y}",
    "tooltip": false
  },

  "custom/launcher": {
    "format": "ΎΝΥ",
    "on-click": "/home/shahid/.config/rofi/app-menu-launch.sh",
    "on-click-right": "RiceSelector",
    "tooltip": false
  },

  "custom/prev": {
    "format": "ΎΒΙ",
    "on-click": "playerctl previous",
    "tooltip": false
  },

  "custom/play-pause": {
    "format": "{}",
    "exec": "playerctl status 2>/dev/null | grep -q 'Playing' && echo 'ΎΒΝ' || echo 'ΎΒΜ'",
    "interval": 1,
    "on-click": "playerctl play-pause",
    "tooltip": false
  },

  "custom/next": {
    "format": "ΎΒΣ",
    "on-click": "playerctl next",
    "tooltip": false
  },

  "custom/mplayer": {
    "format": "ΎΑΒ",
    "on-click": "eww open --toggle music",
    "tooltip": false
  },

  "custom/cava-left": {
    "format": "{}",
    "exec": "/home/shahid/.config/waybar/scripts/cava.sh left",
	"restart-interval": 2,
	"tooltip": false
	},

  "custom/cava-right": {
	"format": "{}",
	"exec": "/home/shahid/.config/waybar/scripts/cava.sh right",
    "restart-interval": 2,
    "tooltip": false
  },

  "custom/updates": {
    "exec": "cat ~/.cache/Updates.txt 2>/dev/null",
    "interval": 1,
    "format": "≤░Λι {}",
    "on-click": "OpenApps --checkupdates",
    "tooltip": false
  },

  "custom/power": {
    "format": "ΎΑΣ",
    "on-click": "/home/shahid/.config/rofi/power-launch.sh",
    "tooltip": false
  }
}
